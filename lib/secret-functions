#!/bin/bash
#
# secret-functions
#
# List, show, and manage Azure Key Vault secrets

secrets() {

  # List secrets in a Key Vault
  #
  #     USAGE: secrets rg/vault-name [rg/vault-name]
  #
  #     $ keyvaults | secrets
  #     kv-prod  db-password     true   2026-12-01T00:00:00Z
  #     kv-prod  api-key         true   (never)
  #     kv-prod  tls-cert-pass   true   2026-08-15T00:00:00Z
  #
  # *Supports pipe from keyvaults:*
  #
  #     $ keyvaults | grep prod | secrets

  [[ "${1:-}" == --help ]] && __bmaz_help && return 0

  local vault_ids=($(skim-stdin "$@"))
  [[ ${#vault_ids[@]} -eq 0 ]] && __bmaz_usage "rg/vault-name [rg/vault-name]" && return 1

  local vault_id
  for vault_id in "${vault_ids[@]}"; do
    __bmaz_parse_resource "$vault_id" || return 1
    az keyvault secret list              \
      --vault-name "$_bmaz_name"         \
      --output tsv                       \
      --query "[].{
        Vault:'$_bmaz_name',
        Name:name,
        Enabled:attributes.enabled,
        Expires:attributes.expires || '(never)'
      }" 2>/dev/null
  done |
    columnise
}


secret-show() {

  # Show the value of a secret
  #
  #     USAGE: secret-show vault-name secret-name
  #
  #     $ secret-show kv-prod db-password
  #     kv-prod  db-password  MyS3cur3P@ss!

  [[ "${1:-}" == --help ]] && __bmaz_help && return 0

  local vault_name="$1"
  local secret_name="$2"
  [[ -z "$vault_name" || -z "$secret_name" ]] && __bmaz_usage "vault-name secret-name" && return 1

  az keyvault secret show            \
    --vault-name "$vault_name"       \
    --name "$secret_name"            \
    --output tsv                     \
    --query "{
      Vault:'$vault_name',
      Name:name,
      Value:value
    }" |
    columnise
}


secret-set() {

  # Set a secret value in a Key Vault
  #
  #     USAGE: secret-set vault-name secret-name secret-value
  #
  #     $ secret-set kv-prod db-password 'NewP@ssw0rd!'
  #     Created: kv-prod/db-password

  [[ "${1:-}" == --help ]] && __bmaz_help && return 0

  local vault_name="$1"
  local secret_name="$2"
  local secret_value="$3"
  [[ -z "$vault_name" || -z "$secret_name" || -z "$secret_value" ]] && \
    __bmaz_usage "vault-name secret-name secret-value" && return 1

  az keyvault secret set             \
    --vault-name "$vault_name"       \
    --name "$secret_name"            \
    --value "$secret_value"          \
    --output tsv                     \
    --query "name" > /dev/null && \
  echo "Created: $vault_name/$secret_name"
}


secret-expiry() {

  # Show secrets with expiry dates (highlights near-expiry)
  #
  #     USAGE: secret-expiry rg/vault-name [rg/vault-name]
  #
  #     $ keyvaults | secret-expiry
  #     kv-prod  db-password    2026-12-01T00:00:00Z
  #     kv-prod  tls-cert-pass  2026-08-15T00:00:00Z
  #
  # Only shows secrets that have an expiry date set.

  [[ "${1:-}" == --help ]] && __bmaz_help && return 0

  local vault_ids=($(skim-stdin "$@"))
  [[ ${#vault_ids[@]} -eq 0 ]] && __bmaz_usage "rg/vault-name [rg/vault-name]" && return 1

  local vault_id
  for vault_id in "${vault_ids[@]}"; do
    __bmaz_parse_resource "$vault_id" || return 1
    az keyvault secret list              \
      --vault-name "$_bmaz_name"         \
      --output tsv                       \
      --query "[?attributes.expires != null].{
        Vault:'$_bmaz_name',
        Name:name,
        Expires:attributes.expires
      }" 2>/dev/null
  done |
  LC_ALL=C sort -t$'\t' -k 3 |
    columnise
}
