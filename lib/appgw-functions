appgw-ssl-certs() {

  # List SSL certificates on Application Gateway(s)
  #
  #     USAGE: appgw-ssl-certs rg/appgw-name [rg/appgw-name]
  #
  #     $ appgws | appgw-ssl-certs
  #     wildcard-cert     KeyVault  prod-rg/web-appgw
  #     api-cert          Uploaded  prod-rg/web-appgw

  [[ "${1:-}" == --help ]] && __bmaz_help && return 0

  local appgw_ids=($(skim-stdin "$@"))
  [[ ${#appgw_ids[@]} -eq 0 ]] && __bmaz_usage "rg/appgw-name [rg/appgw-name]" && return 1

  local appgw_id
  for appgw_id in "${appgw_ids[@]}"; do
    __bmaz_parse_resource "$appgw_id" || return 1
    az network application-gateway ssl-cert list  \
      --resource-group "$_bmaz_rg"                \
      --gateway-name "$_bmaz_name"                \
      --output tsv                                \
      --query "[].{
        Name:name,
        Source:keyVaultSecretId && 'KeyVault' || 'Uploaded',
        AppGW:'$appgw_id'
      }"
  done |
    columnise
}


