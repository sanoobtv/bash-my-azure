#!/bin/bash
#
# appgw-functions
#
# List and inspect Azure Application Gateways, listeners, rules, SSL certs, and profiles

appgws() {

  # List Application Gateways
  #
  #     $ appgws
  #     prod-rg/web-appgw       Standard_v2  2  Running    eastus     Succeeded
  #     prod-rg/api-appgw       WAF_v2       3  Running    eastus     Succeeded
  #     dev-rg/dev-appgw        Standard_v2  1  Running    westus2    Succeeded
  #
  # *Optionally provide a filter string:*
  #
  #     $ appgws web
  #     prod-rg/web-appgw  Standard_v2  2  Running  eastus  Succeeded

  [[ "${1:-}" == --help ]] && __bmaz_help && return 0

  local filters=$(__bmaz_read_filters "$@")

  local rg_args=()
  [[ -n "$BMAZ_DEFAULT_RG" ]] && rg_args=(--resource-group "$BMAZ_DEFAULT_RG")

  az network application-gateway list "${rg_args[@]}" \
    --output tsv                                      \
    --query "[].{
      Id:join('/', [resourceGroup, name]),
      Tier:sku.tier,
      Capacity:sku.capacity,
      OperationalState:operationalState,
      Location:location,
      State:provisioningState
    }" |
  grep -E -- "$filters" |
  LC_ALL=C sort -t$'\t' -k 1 |
    columnise
}


appgw-listeners() {

  # List HTTP listeners for Application Gateway(s)
  #
  #     USAGE: appgw-listeners rg/appgw-name [rg/appgw-name]
  #
  #     $ appgws | appgw-listeners
  #     https-listener   Https  443  www.example.com     prod-rg/web-appgw
  #     http-listener    Http   80   www.example.com     prod-rg/web-appgw
  #     api-listener     Https  443  api.example.com     prod-rg/web-appgw

  [[ "${1:-}" == --help ]] && __bmaz_help && return 0

  local appgw_ids=($(skim-stdin "$@"))
  [[ ${#appgw_ids[@]} -eq 0 ]] && __bmaz_usage "rg/appgw-name [rg/appgw-name]" && return 1

  local appgw_id
  for appgw_id in "${appgw_ids[@]}"; do
    __bmaz_parse_resource "$appgw_id" || return 1
    az network application-gateway http-listener list \
      --resource-group "$_bmaz_rg"                    \
      --gateway-name "$_bmaz_name"                    \
      --output tsv                                    \
      --query "[].{
        Name:name,
        Protocol:protocol,
        Port:frontendPort && split(frontendPort.id, '/') | [-1] || 'default',
        Host:hostName || hostNames[0] || '*',
        AppGW:'$appgw_id'
      }"
  done |
    columnise
}


appgw-rules() {

  # List request routing rules for Application Gateway(s)
  #
  #     USAGE: appgw-rules rg/appgw-name [rg/appgw-name]
  #
  #     $ appgws | grep web | appgw-rules
  #     https-rule  Basic      100  https-listener   prod-rg/web-appgw
  #     http-rule   PathBased  200  http-listener    prod-rg/web-appgw

  [[ "${1:-}" == --help ]] && __bmaz_help && return 0

  local appgw_ids=($(skim-stdin "$@"))
  [[ ${#appgw_ids[@]} -eq 0 ]] && __bmaz_usage "rg/appgw-name [rg/appgw-name]" && return 1

  local appgw_id
  for appgw_id in "${appgw_ids[@]}"; do
    __bmaz_parse_resource "$appgw_id" || return 1
    az network application-gateway rule list      \
      --resource-group "$_bmaz_rg"                \
      --gateway-name "$_bmaz_name"                \
      --output tsv                                \
      --query "[].{
        Name:name,
        Type:ruleType,
        Priority:priority,
        Listener:split(httpListener.id, '/') | [-1],
        AppGW:'$appgw_id'
      }"
  done |
    columnise
}


