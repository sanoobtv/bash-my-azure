  # List frontend IP configurations for Application Gateway(s)
  #
  #     USAGE: appgw-frontend-ips rg/appgw-name [rg/appgw-name]
  #
  #     $ appgws | grep web | appgw-frontend-ips
  #     appGwPublicFrontendIp   Public   20.53.1.100  prod-rg/web-appgw
  #     appGwPrivateFrontendIp  Private  10.0.1.50    prod-rg/web-appgw

  [[ "${1:-}" == --help ]] && __bmaz_help && return 0

  local appgw_ids=($(skim-stdin "$@"))
  [[ ${#appgw_ids[@]} -eq 0 ]] && __bmaz_usage "rg/appgw-name [rg/appgw-name]" && return 1

  local appgw_id
  for appgw_id in "${appgw_ids[@]}"; do
    __bmaz_parse_resource "$appgw_id" || return 1
    az network application-gateway frontend-ip list \
      --resource-group "$_bmaz_rg"                  \
      --gateway-name "$_bmaz_name"                  \
      --output tsv                                  \
