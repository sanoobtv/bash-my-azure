appgw-probes() {

  # List custom health probes for Application Gateway(s)
  #
  #     USAGE: appgw-probes rg/appgw-name [rg/appgw-name]
  #
  #     $ appgws | grep web | appgw-probes
  #     web-probe   Https  /health   30  3  prod-rg/web-appgw
  #     api-probe   Http   /readyz   15  2  prod-rg/web-appgw

  [[ "${1:-}" == --help ]] && __bmaz_help && return 0

  local appgw_ids=($(skim-stdin "$@"))
  [[ ${#appgw_ids[@]} -eq 0 ]] && __bmaz_usage "rg/appgw-name [rg/appgw-name]" && return 1

  local appgw_id
  for appgw_id in "${appgw_ids[@]}"; do
    __bmaz_parse_resource "$appgw_id" || return 1
