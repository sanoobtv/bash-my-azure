  # List SSL profiles for Application Gateway(s)
  #
  #     USAGE: appgw-ssl-profiles rg/appgw-name [rg/appgw-name]
  #
  #     $ appgws | grep web | appgw-ssl-profiles
  #     strict-profile   AppGwSslPolicy20220101S  1  prod-rg/web-appgw
  #     default-profile  AppGwSslPolicy20220101   0  prod-rg/web-appgw

  [[ "${1:-}" == --help ]] && __bmaz_help && return 0

  local appgw_ids=($(skim-stdin "$@"))
  [[ ${#appgw_ids[@]} -eq 0 ]] && __bmaz_usage "rg/appgw-name [rg/appgw-name]" && return 1

  local appgw_id
  for appgw_id in "${appgw_ids[@]}"; do
    __bmaz_parse_resource "$appgw_id" || return 1
    az network application-gateway ssl-profile list \
      --resource-group "$_bmaz_rg"                  \
      --gateway-name "$_bmaz_name"                  \
