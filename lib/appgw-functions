appgw-frontend-ips() {

  # List frontend IP configurations for Application Gateway(s)
  #
  #     USAGE: appgw-frontend-ips rg/appgw-name [rg/appgw-name]
  #
  #     $ appgws | grep web | appgw-frontend-ips
  #     appGwPublicFrontendIp   Public   20.53.1.100  prod-rg/web-appgw
  #     appGwPrivateFrontendIp  Private  10.0.1.50    prod-rg/web-appgw

  [[ "${1:-}" == --help ]] && __bmaz_help && return 0

  local appgw_ids=($(skim-stdin "$@"))
  [[ ${#appgw_ids[@]} -eq 0 ]] && __bmaz_usage "rg/appgw-name [rg/appgw-name]" && return 1

  local appgw_id
  for appgw_id in "${appgw_ids[@]}"; do
    __bmaz_parse_resource "$appgw_id" || return 1
    local rg="$_bmaz_rg"
    az network application-gateway frontend-ip list \
      --resource-group "$rg"                        \
      --gateway-name "$_bmaz_name"                  \
      --output tsv                                  \
      --query "[].{
        Name:name,
        PrivateIP:privateIPAddress,
        PubIPId:publicIPAddress.id,
        AppGW:'$appgw_id'
      }" |
    while IFS=$'\t' read -r name private_ip pub_id appgw; do
      local ip_type ip_addr
      if [[ -n "$private_ip" && "$private_ip" != "None" ]]; then
        ip_type="Private"
        ip_addr="$private_ip"
      elif [[ -n "$pub_id" && "$pub_id" != "None" ]]; then
        ip_type="Public"
        local pip_name="${pub_id##*/}"
        ip_addr=$(az network public-ip show \
          --resource-group "$rg" \
          --name "$pip_name" \
          --query "ipAddress" -o tsv 2>/dev/null)
        [[ -z "$ip_addr" ]] && ip_addr="(unallocated)"
      else
        ip_type="Public"
        ip_addr="(unallocated)"
      fi
      printf '%s\t%s\t%s\t%s\n' "$name" "$ip_type" "$ip_addr" "$appgw"
    done
  done |
    columnise
}
