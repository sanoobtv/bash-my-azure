cosmosdb-accounts() {

  # List Cosmos DB Accounts
  #
  #     $ cosmosdb-accounts
  #     prod-rg/cosmos-prod  australiaeast  GlobalDocumentDB  Succeeded  Session
  #     dev-rg/cosmos-dev    australiaeast  GlobalDocumentDB  Succeeded  Eventual
  #
  # *Optionally provide a filter string:*
  #
  #     $ cosmosdb-accounts prod
  #     prod-rg/cosmos-prod  australiaeast  GlobalDocumentDB  Succeeded  Session

  [[ "${1:-}" == --help ]] && __bmaz_help && return 0

  local filters=$(__bmaz_read_filters "$@")

  local rg_args=()
  [[ -n "$BMAZ_DEFAULT_RG" ]] && rg_args=(--resource-group "$BMAZ_DEFAULT_RG")

  az cosmosdb list "${rg_args[@]}" \
    --output tsv                   \
    --query "[].{
      Id:join('/', [resourceGroup, name]),
      Location:locations[0].locationName,
      Kind:databaseAccountOfferType,
      State:provisioningState,
      Consistency:consistencyPolicy.defaultConsistencyLevel
    }" |
  grep -E -- "$filters" |
  LC_ALL=C sort -t$'\t' -k 1 |
    columnise
}
