vm-ssh() {

  # SSH into a VM (uses first public IP, falls back to private IP)
  #
  #     USAGE: vm-ssh rg/name
  #
  #     $ vms | grep web01 | vm-ssh

  [[ "${1:-}" == --help ]] && __bmaz_help && return 0

  local vm_ids=($(skim-stdin "$@"))
  [[ ${#vm_ids[@]} -eq 0 ]] && __bmaz_usage "rg/name" && return 1

  # Only SSH to first VM (bash arrays are 0-indexed; bmaz always runs under bash)
  local vm_id="${vm_ids[0]}"
  __bmaz_parse_resource "$vm_id" || return 1

  local ip
  ip=$(az vm list-ip-addresses          \
    --resource-group "$_bmaz_rg"         \
    --name "$_bmaz_name"                 \
    --query "[0].virtualMachine.network.publicIpAddresses[0].ipAddress" \
    --output tsv)

  # Fallback to private IP if no public
  if [[ -z "$ip" || "$ip" == "None" ]]; then
    ip=$(az vm list-ip-addresses         \
      --resource-group "$_bmaz_rg"       \
      --name "$_bmaz_name"               \
      --query "[0].virtualMachine.network.privateIpAddresses[0]" \
      --output tsv)
  fi

  [[ -z "$ip" || "$ip" == "None" ]] && __bmaz_error "No IP found for $vm_id" && return 1

  local user
  user=$(az vm show                      \
    --resource-group "$_bmaz_rg"         \
    --name "$_bmaz_name"                 \
    --query "osProfile.adminUsername"    \
    --output tsv)

  echo "Connecting to $vm_id ($ip) as $user..."
  ssh "${user}@${ip}"
}


vm-delete() {

  # Delete VM(s) (with confirmation)
  #
  #     USAGE: vm-delete rg/name [rg/name]
  #
  #     $ vms | grep test | vm-delete
  #     You are about to delete the following VMs:
  #       dev-rg/test01
  #     Are you sure you want to continue? y

  [[ "${1:-}" == --help ]] && __bmaz_help && return 0

  local vm_ids=($(skim-stdin "$@"))
  [[ ${#vm_ids[@]} -eq 0 ]] && __bmaz_usage "rg/name [rg/name]" && return 1

  echo "You are about to delete the following VMs:"
  for vm_id in "${vm_ids[@]}"; do
    echo "  $vm_id"
  done

  [ -t 0 ] || exec </dev/tty # reattach keyboard to STDIN
  local regex_yes="^[Yy]$"
  read -p "Are you sure you want to continue? " -n 1 -r
  echo
  if [[ $REPLY =~ $regex_yes ]]; then
    for vm_id in "${vm_ids[@]}"; do
      __bmaz_parse_resource "$vm_id" || return 1
      echo "Deleting $vm_id..."
      az vm delete                     \
        --resource-group "$_bmaz_rg"   \
        --name "$_bmaz_name"           \
        --yes --no-wait
    done
  fi
}
